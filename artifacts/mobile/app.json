{
  "expo": {
    "name": "Bolso",
    "slug": "bolso",
    "owner": "deywd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bolso.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Permita o reconhecimento de voz para transcrever suas mensagens.",
        "NSMicrophoneUsageDescription": "Permita o microfone para ditar mensagens ao assistente."
      }
    },
    "android": {
      "package": "com.bolso.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0a0a0c"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permita o microfone para ditar mensagens ao assistente.",
          "speechRecognitionPermission": "Permita o reconhecimento de voz para transcrever suas mensagens."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "3f0aa034-693f-47af-8fc1-8125fd5dc423"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3f0aa034-693f-47af-8fc1-8125fd5dc423"
    }
  }
}
